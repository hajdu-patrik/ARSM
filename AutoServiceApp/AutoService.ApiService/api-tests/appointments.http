@AutoService_ApiService_HostAddress = https://localhost:5200
@AdminPassword = Test_Jelszo.420
@AdminEmail = gabor.kovacs@gmail.com
@NonAdminEmail = peter.nagy@gmail.com
@CustomerId = 6
@CustomerVehicleId = 1
@AnotherCustomerVehicleId = 2
@PrimaryMechanicId = 2
@SecondaryMechanicId = 3
@UnknownMechanicId = 99999
@UnknownVehicleId = 99999
@PastCancelledApptId = 1
@SingleAssignedApptId = 2

#  APPOINTMENTS
# ─────────────────────────────────────────────────────────────

@ApptId = 1

### [Setup][Appointments] Login as non-admin mechanic (session prerequisite)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{NonAdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Positive][Appointments] List month appointments (2026-04)
GET {{AutoService_ApiService_HostAddress}}/api/appointments?year=2026&month=4

###

### [Positive][Appointments] List today's appointments
GET {{AutoService_ApiService_HostAddress}}/api/appointments/today

###

### [Positive][Appointments] Claim appointment by id
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/claim

###

### [Positive][Appointments] Update appointment status to InProgress
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/status
Content-Type: application/json

{
  "status": "InProgress"
}

###

### [Positive][Appointments] Update appointment status to Completed
# Response includes completedAt (DateTime) and canceledAt (null).
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/status
Content-Type: application/json

{
  "status": "Completed"
}

###

### [Positive][Appointments] Update appointment status to Cancelled
# Response includes canceledAt (DateTime) and completedAt (null).
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{PastCancelledApptId}}/status
Content-Type: application/json

{
  "status": "Cancelled"
}

###

### [Positive][Appointments] Reopen cancelled appointment to InProgress (past-cancelled remains editable)
# Cancelled appointments can be moved back to active states even after cancellation.
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{PastCancelledApptId}}/status
Content-Type: application/json

{
  "status": "InProgress"
}

###

### [Positive][Appointments] Move reopened appointment to Completed
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{PastCancelledApptId}}/status
Content-Type: application/json

{
  "status": "Completed"
}

###

### [Negative][Appointments] Update appointment status with invalid value (400 expected)
# Valid statuses are: InProgress, Completed, Cancelled. "Scheduled" is no longer valid.
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/status
Content-Type: application/json

{
  "status": "Scheduled"
}

###

### [Negative][Appointments] Claim non-existent appointment (404 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/99999/claim

###

### [Negative][Appointments] Mechanic cannot unclaim when appointment would have zero mechanics (422 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/claim

###

### [Negative][Appointments] Update non-existent appointment status (404 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/99999/status
Content-Type: application/json

{
  "status": "InProgress"
}

###

### [Negative][Appointments] Non-admin cannot create customer appointment (403 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{CustomerVehicleId}},
  "scheduledDate": "2026-04-17T09:00:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": [{{PrimaryMechanicId}}]
}

###

### [Setup][Appointments] Login as admin (session prerequisite for AdminOnly endpoints)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Positive][Appointments] Admin creates appointment for customer
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{CustomerVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": [{{PrimaryMechanicId}}, {{SecondaryMechanicId}}]
}

###

### [Negative][Appointments] Admin create fails when customer does not exist (404 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/99999/appointments
Content-Type: application/json

{
  "vehicleId": {{CustomerVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": [{{PrimaryMechanicId}}]
}

###

### [Negative][Appointments] Admin create fails when vehicle is not owned by customer (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{AnotherCustomerVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": [{{PrimaryMechanicId}}]
}

###

### [Negative][Appointments] Admin create fails when vehicle does not exist (404 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{UnknownVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": [{{PrimaryMechanicId}}]
}

###

### [Negative][Appointments] Admin create fails for empty mechanicIds (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{CustomerVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": []
}

###

### [Negative][Appointments] Admin create fails for duplicate mechanicIds (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{CustomerVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": [{{PrimaryMechanicId}}, {{PrimaryMechanicId}}]
}

###

### [Negative][Appointments] Admin create fails for non-positive mechanicIds (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{CustomerVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": [0]
}

###

### [Negative][Appointments] Admin create fails for empty taskDescription (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{CustomerVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "   ",
  "mechanicIds": [{{PrimaryMechanicId}}]
}

###

### [Negative][Appointments] Admin create fails for invalid mechanicIds (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{CustomerId}}/appointments
Content-Type: application/json

{
  "vehicleId": {{CustomerVehicleId}},
  "scheduledDate": "2026-04-18T10:30:00",
  "taskDescription": "Uj idopont felvetele admin oldalon",
  "mechanicIds": [{{UnknownMechanicId}}]
}

###

# ── Admin Assign / Unassign ──────────────────────────────────────────────────
# Prerequisites: login as admin (session cookie required for AdminOnly endpoints).
# Set @CancelledApptId to an appointment that is in Cancelled status.

@MechanicIdToAssign = 2
@CancelledApptId = 1

### [Negative][Appointments] Admin assign mechanic to cancelled appointment (422 expected)
# Returns 422 Unprocessable Entity: cannot modify mechanics on a cancelled appointment.
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{CancelledApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin unassign mechanic from cancelled appointment (422 expected)
# Returns 422 Unprocessable Entity: cannot modify mechanics on a cancelled appointment.
DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{CancelledApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin cannot unassign last mechanic from appointment (422 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/{{MechanicIdToAssign}}

###

@AutoService_ApiService_HostAddress = https://localhost:5200
@AdminPassword = Test_Jelszo.420
@NonAdminEmail = peter.nagy@gmail.com

#  APPOINTMENTS
# ─────────────────────────────────────────────────────────────

@ApptId = 1

### [Setup][Appointments] Login as non-admin mechanic (session prerequisite)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{NonAdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Positive][Appointments] List month appointments (2026-04)
GET {{AutoService_ApiService_HostAddress}}/api/appointments?year=2026&month=4

###

### [Positive][Appointments] List today's appointments
GET {{AutoService_ApiService_HostAddress}}/api/appointments/today

###

### [Positive][Appointments] Claim appointment by id
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/claim

###

### [Positive][Appointments] Update appointment status to InProgress
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/status
Content-Type: application/json

{
  "status": "InProgress"
}

###

### [Positive][Appointments] Update appointment status to Completed
# Response includes completedAt (DateTime) and canceledAt (null).
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/status
Content-Type: application/json

{
  "status": "Completed"
}

###

### [Positive][Appointments] Update appointment status to Cancelled
# Response includes canceledAt (DateTime) and completedAt (null).
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/status
Content-Type: application/json

{
  "status": "Cancelled"
}

###

### [Negative][Appointments] Update appointment status with invalid value (400 expected)
# Valid statuses are: InProgress, Completed, Cancelled. "Scheduled" is no longer valid.
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{ApptId}}/status
Content-Type: application/json

{
  "status": "Scheduled"
}

###

### [Negative][Appointments] Claim non-existent appointment (404 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/99999/claim

###

### [Negative][Appointments] Update non-existent appointment status (404 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/99999/status
Content-Type: application/json

{
  "status": "InProgress"
}

###

# ── Admin Assign / Unassign ──────────────────────────────────────────────────
# Prerequisites: login as admin (session cookie required for AdminOnly endpoints).
# Set @CancelledApptId to an appointment that is in Cancelled status.

@MechanicIdToAssign = 2
@CancelledApptId = 1

### [Negative][Appointments] Admin assign mechanic to cancelled appointment (422 expected)
# Returns 422 Unprocessable Entity: cannot modify mechanics on a cancelled appointment.
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{CancelledApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin unassign mechanic from cancelled appointment (422 expected)
# Returns 422 Unprocessable Entity: cannot modify mechanics on a cancelled appointment.
DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{CancelledApptId}}/assign/{{MechanicIdToAssign}}

###

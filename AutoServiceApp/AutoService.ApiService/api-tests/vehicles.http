@AutoService_ApiService_HostAddress = https://localhost:5200
@AdminEmail = gabor.kovacs@gmail.com
@AdminPassword = Test_Jelszo.420
@NonAdminEmail = peter.nagy@gmail.com

#  VEHICLES
# ─────────────────────────────────────────────────────────────

# Seed data (fresh DB): mechanics are ids 1–5, customers are 6–10.
# Anna Toth (customer 6) owns vehicle with plate ABC-101 (vehicle id 1).
# Adjust these variables to match actual IDs from your database.
@SeedCustomerId = 6
@SeedVehicleId = 1
@NonExistentCustomerId = 99999
@NonExistentVehicleId = 99999

### [Setup][Vehicles] Login as admin (session prerequisite)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

# ─────────────────────────────────────────────────────────────
#  LIST VEHICLES FOR CUSTOMER
# ─────────────────────────────────────────────────────────────

### [Positive][Vehicles] List vehicles for seeded customer (200 expected)
GET {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}/vehicles

###

### [Negative][Vehicles] List vehicles for non-existent customer (404 expected)
GET {{AutoService_ApiService_HostAddress}}/api/customers/{{NonExistentCustomerId}}/vehicles

###

# ─────────────────────────────────────────────────────────────
#  GET VEHICLE BY ID
# ─────────────────────────────────────────────────────────────

### [Positive][Vehicles] Get vehicle by id (200 expected, includes customer summary)
GET {{AutoService_ApiService_HostAddress}}/api/vehicles/{{SeedVehicleId}}

###

### [Negative][Vehicles] Get non-existent vehicle (404 expected)
GET {{AutoService_ApiService_HostAddress}}/api/vehicles/{{NonExistentVehicleId}}

###

# ─────────────────────────────────────────────────────────────
#  CREATE VEHICLE
# ─────────────────────────────────────────────────────────────

### [Positive][Vehicles] Admin creates vehicle for customer (201 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}/vehicles
Content-Type: application/json

{
  "licensePlate": "NEW-001",
  "brand": "Skoda",
  "model": "Octavia",
  "year": 2020,
  "mileageKm": 45000,
  "enginePowerHp": 150,
  "engineTorqueNm": 320
}

###


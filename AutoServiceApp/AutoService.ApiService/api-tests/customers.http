@AutoService_ApiService_HostAddress = https://localhost:5200
@AdminEmail = gabor.kovacs@example.com
@AdminPassword = {{$processEnv ARSM_ADMIN_PASSWORD}}
@NonAdminEmail = peter.nagy@example.com
@SeedCustomerId = 1
@NonExistentCustomerId = 99999

### [Setup][Customers] Login as admin (session prerequisite)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

# ─────────────────────────────────────────────────────────────
#  LIST CUSTOMERS
# ─────────────────────────────────────────────────────────────

### [Positive][Customers] List all customers (200 expected)
GET {{AutoService_ApiService_HostAddress}}/api/customers

###

### [Setup][Customers] Logout admin, login as non-admin for auth check
POST {{AutoService_ApiService_HostAddress}}/api/auth/logout

###

### [Setup][Customers] Login as non-admin mechanic
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{NonAdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Positive][Customers] Non-admin can list customers (200 expected — read is authorized, not admin-only)
GET {{AutoService_ApiService_HostAddress}}/api/customers

###

### [Positive][Customers] Lookup customer by email for scheduler flow (200 expected)
GET {{AutoService_ApiService_HostAddress}}/api/customers/by-email?email=anna.toth@example.com

###

### [Positive][Customers] Lookup customer by email with casing/whitespace normalization (200 expected)
GET {{AutoService_ApiService_HostAddress}}/api/customers/by-email?email=%20ANNA.TOTH@example.com%20

###

### [Negative][Customers] Lookup customer by invalid email format (422 expected)
GET {{AutoService_ApiService_HostAddress}}/api/customers/by-email?email=not-an-email

###

### [Negative][Customers] Lookup customer by unknown email (404 expected)
GET {{AutoService_ApiService_HostAddress}}/api/customers/by-email?email=unknown.scheduler.lookup@example.com

###

### [Negative][Customers] Unauthenticated list customers (401 expected)
# NOTE: Run this after manually clearing cookies / in a fresh session.
# Uncomment to use:
# GET {{AutoService_ApiService_HostAddress}}/api/customers

###

# ─────────────────────────────────────────────────────────────
#  GET CUSTOMER BY ID
# ─────────────────────────────────────────────────────────────

### [Setup][Customers] Login as admin for single-customer queries
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Positive][Customers] Get seeded customer by id (200 expected, includes vehicle list)
GET {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}

###

### [Negative][Customers] Get non-existent customer (404 expected)
GET {{AutoService_ApiService_HostAddress}}/api/customers/{{NonExistentCustomerId}}

###

# ─────────────────────────────────────────────────────────────
#  CREATE CUSTOMER
# ─────────────────────────────────────────────────────────────

### [Positive][Customers] Admin creates new customer (201 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Test",
  "middleName": null,
  "lastName": "Customer",
  "email": "test.customer.new@example.com",
  "phoneNumber": "+36301234567"
}

###

### [Positive][Customers] Admin creates customer without optional fields (201 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Minimal",
  "middleName": null,
  "lastName": "Customer",
  "email": "minimal.customer@example.com",
  "phoneNumber": null
}

###

### [Negative][Customers] Create customer with missing required fields (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "",
  "middleName": null,
  "lastName": "Customer",
  "email": "bad.create@example.com",
  "phoneNumber": null
}

###

### [Negative][Customers] Create customer with firstName containing a space (422 expected)
# "First name may only contain letters and hyphens."
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Mary Jane",
  "middleName": null,
  "lastName": "Customer",
  "email": "firstname.space.customer@example.com",
  "phoneNumber": null
}

###

### [Negative][Customers] Create customer with firstName containing a digit (422 expected)
# "First name may only contain letters and hyphens."
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "John2",
  "middleName": null,
  "lastName": "Customer",
  "email": "firstname.digit.customer@example.com",
  "phoneNumber": null
}

###

### [Negative][Customers] Create customer with lastName containing a special character (422 expected)
# "Last name may only contain letters and hyphens."
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Valid",
  "middleName": null,
  "lastName": "O'Brien",
  "email": "lastname.apostrophe.customer@example.com",
  "phoneNumber": null
}

###

### [Negative][Customers] Create customer with middleName containing a space (422 expected)
# "Middle name may only contain letters and hyphens."
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Valid",
  "middleName": "Van Der",
  "lastName": "Customer",
  "email": "middlename.space.customer@example.com",
  "phoneNumber": null
}

###

### [Negative][Customers] Create customer with invalid email format (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Invalid",
  "middleName": null,
  "lastName": "Email",
  "email": "invalid-email-format",
  "phoneNumber": null
}

###

### [Negative][Customers] Create customer with invalid Hungarian phone format (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Invalid",
  "middleName": null,
  "lastName": "Phone",
  "email": "invalid.customer.phone@example.com",
  "phoneNumber": "12345"
}

###

### [Negative][Customers] Create customer with duplicate email (409 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Duplicate",
  "middleName": null,
  "lastName": "Email",
  "email": "anna.toth@example.com",
  "phoneNumber": null
}

###

### [Setup][Customers] Logout admin, login as non-admin for forbidden write check
POST {{AutoService_ApiService_HostAddress}}/api/auth/logout

###

### [Setup][Customers] Login as non-admin mechanic
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{NonAdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Negative][Customers] Non-admin cannot create customer (403 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers
Content-Type: application/json

{
  "firstName": "Blocked",
  "middleName": null,
  "lastName": "ByPolicy",
  "email": "blocked.by.policy@example.com",
  "phoneNumber": null
}

###

# ─────────────────────────────────────────────────────────────
#  UPDATE CUSTOMER
# ─────────────────────────────────────────────────────────────

### [Setup][Customers] Login as admin for update tests
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Positive][Customers] Admin updates existing customer (204 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}
Content-Type: application/json

{
  "firstName": "Anna",
  "middleName": "Maria",
  "lastName": "Toth-Updated",
  "email": "anna.toth@example.com",
  "phoneNumber": "+36304445566"
}

###


{
    "servers": {
        "pencil-design-tool": {
            "command": "npx",
            "args": [
                "-y",
                "-p",
                "@open-pencil/mcp",
                "openpencil-mcp"
            ]
        },
        "context-mode": {
            "command": "context-mode"
        },
        "aspire": {
            "type": "stdio",
            "command": "dotnet",
            "args": [
                "tool",
                "run",
                "aspire",
                "--",
                "mcp",
                "start"
            ]
        }
    }
}

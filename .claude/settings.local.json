{
  "env": {
    "BASH_MAX_OUTPUT_LENGTH": "150000"
  },
  "permissions": {
    "allow": [
      "Bash(find:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vite:*)",
      "Bash(xargs grep:*)",
      "Bash(wc *)",
      "Bash(dotnet build:*)",
      "Bash(dotnet list:*)",
      "Bash(npm audit:*)",
      "Bash(npm audit fix:*)",
      "Bash(ls *)",
      "Bash(mv *)"
    ],
    "deny": [
      "Read(node_modules/**)",
      "Read(dist/**)",
      "Read(.next/**)",
      "Read(.lock)",
      "Read(coverage/**)"
    ]
  },
  "autocompact_percentage_override": 75
}

@AutoService_ApiService_HostAddress = https://localhost:5200
@TestPassword = Test@1234
@AdminEmail = gabor.kovacs@example.com
@AdminPassword = {{$processEnv ARSM_ADMIN_PASSWORD}}
@MatrixRunSuffix = 20260403a
@CurrentAdminMechanicId = 6
@MechanicIdWithSoleAssignments = 7
@MechanicIdCandidateForDeletion = 8
@UnknownMechanicId = 99999
@NonAdminEmail = peter.nagy@example.com
@NonAdminPassword = {{$processEnv ARSM_ADMIN_PASSWORD}}

### [Setup][Admin] Login as admin (session prerequisite)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Positive][Admin] List all mechanics
# Response items include isAdmin and hasProfilePicture.
GET {{AutoService_ApiService_HostAddress}}/api/admin/mechanics

###

### [Negative][Admin] Try deleting self mechanic (403 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/admin/mechanics/{{CurrentAdminMechanicId}}

###

### [Negative][Admin] Cannot delete mechanic if it would leave appointments unassigned (422 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/admin/mechanics/{{MechanicIdWithSoleAssignments}}

###

# Preconditions: database has exactly one mechanic left and target is that mechanic.
### [Negative][Admin] Cannot delete last remaining mechanic globally (422 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/admin/mechanics/{{MechanicIdCandidateForDeletion}}

###

# Preconditions: target is non-admin, not self, and all its appointments are reassigned.
### [Positive][Admin] Delete non-admin mechanic when invariants hold
DELETE {{AutoService_ApiService_HostAddress}}/api/admin/mechanics/{{MechanicIdCandidateForDeletion}}

###

# Preconditions: induce concurrent update/delete contention on the same mechanic in another client/session.
### [Negative][Admin] Concurrent mechanic delete contention returns conflict (409 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/admin/mechanics/{{MechanicIdCandidateForDeletion}}

###

# Preconditions: force linked identity deletion to fail (for example fault-inject UserManager.DeleteAsync failure).
### [Negative][Admin][Manual] Linked identity delete failure returns server error (500 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/admin/mechanics/{{MechanicIdCandidateForDeletion}}

###

### [Negative][Admin] Cannot delete unknown mechanic (404 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/admin/mechanics/{{UnknownMechanicId}}

###

### [Setup][Admin] Login as non-admin for forbidden access check
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{NonAdminEmail}}",
  "password": "{{NonAdminPassword}}"
}

###

### [Negative][Admin] Non-admin cannot list mechanics (403 expected)
GET {{AutoService_ApiService_HostAddress}}/api/admin/mechanics

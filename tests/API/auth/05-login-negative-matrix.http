# ─────────────────────────────────────────────────────────────
# AUTH - LOGIN NEGATIVE MATRIX
# ─────────────────────────────────────────────────────────────

@AutoService_ApiService_HostAddress = {{$processEnv AutoService_ApiService_HostAddress}}
@TestPassword = {{$processEnv ARSM_TEST_PASSWORD}}
@TestWrongPassword = {{$processEnv ARSM_TEST_WRONG_PASSWORD}}
@AdminEmail = {{$processEnv ARSM_TEST_ADMIN_EMAIL}}
@AdminPassword = {{$processEnv ARSM_TEST_ADMIN_PASSWORD}}
@NonAdminEmail = {{$processEnv ARSM_TEST_MECHANIC_EMAIL}}
@NonAdminPassword = {{$processEnv ARSM_TEST_MECHANIC_PASSWORD}}
@MatrixEuPhoneCanonical = +4915112345678


# ─────────────────────────────────────────────────────────────

### [Case][Auth] POST /api/auth/login

POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "phoneNumber": "06 1 234 5678",
  "password": "{{TestPassword}}"
}

###

### [Positive][Login Phone Matrix] EU phone (+49) for matrix user
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "phoneNumber": "{{MatrixEuPhoneCanonical}}",
  "password": "{{TestPassword}}"
}

###

### [Negative][Login Phone Matrix] Invalid phone format
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "phoneNumber": "12345",
  "password": "{{TestPassword}}"
}

###

### [Negative][Login Phone Matrix] Unsupported area/prefix
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "phoneNumber": "06 12 123 4567",
  "password": "{{TestPassword}}"
}

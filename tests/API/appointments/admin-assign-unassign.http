# ── Admin Assign / Unassign ──────────────────────────────────────────────────
# Prerequisites: login as admin (session cookie required for AdminOnly endpoints).
# Set @CancelledApptId to an appointment that is in Cancelled status.

@AutoService_ApiService_HostAddress = {{$processEnv AutoService_ApiService_HostAddress}}
@AdminEmail = {{$processEnv ARSM_TEST_ADMIN_EMAIL}}
@AdminPassword = {{$processEnv ARSM_TEST_ADMIN_PASSWORD}}
@NonAdminEmail = {{$processEnv ARSM_TEST_MECHANIC_EMAIL}}
@NonAdminPassword = {{$processEnv ARSM_TEST_MECHANIC_PASSWORD}}
@SingleAssignedApptId = 2
@SecondaryMechanicId = 8

@MechanicIdToAssign = 2
@CancelledApptId = 5
@CompletedApptId = 1


# ─────────────────────────────────────────────────────────────

### [Setup][Appointments] Login as admin (session prerequisite for AdminOnly endpoints)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Negative][Appointments] Admin assign mechanic to completed appointment (422 expected)
# Returns 422 Unprocessable Entity with code: appointment_completed.
### [Case][Appointments] PUT /api/appointments/{{CompletedApptId}}/assign/{{MechanicIdToAssign}}

PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{CompletedApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin unassign mechanic from completed appointment (422 expected)
# Returns 422 Unprocessable Entity with code: appointment_completed.
### [Case][Appointments] DELETE /api/appointments/{{CompletedApptId}}/assign/{{MechanicIdToAssign}}

DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{CompletedApptId}}/assign/{{MechanicIdToAssign}}

###

### [Positive][Appointments] Admin assign mechanic to appointment
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/{{SecondaryMechanicId}}

###

### [Positive][Appointments] Admin unassign mechanic from appointment
DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/{{SecondaryMechanicId}}

###

### [Negative][Appointments] Admin assign mechanic to cancelled appointment (422 expected)
# Returns 422 Unprocessable Entity with code: appointment_cancelled.
### [Case][Appointments] PUT /api/appointments/{{CancelledApptId}}/assign/{{MechanicIdToAssign}}

PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{CancelledApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin unassign mechanic from cancelled appointment (422 expected)
# Returns 422 Unprocessable Entity with code: appointment_cancelled.
### [Case][Appointments] DELETE /api/appointments/{{CancelledApptId}}/assign/{{MechanicIdToAssign}}

DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{CancelledApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin cannot unassign last mechanic from appointment (422 expected)
# Expected error code: last_assigned_mechanic.
DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin assign to non-existent appointment (404 expected)
# Expected error code: appointment_not_found.
### [Case][Appointments] PUT /api/appointments/99999/assign/{{MechanicIdToAssign}}

PUT {{AutoService_ApiService_HostAddress}}/api/appointments/99999/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin assign non-existent mechanic (404 expected)
# Expected error code: mechanic_not_found.
### [Case][Appointments] PUT /api/appointments/{{SingleAssignedApptId}}/assign/99999

PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/99999

###

### [Negative][Appointments] Admin assign mechanic already assigned (409 expected)
# Expected error code: already_assigned.
### [Case][Appointments] PUT /api/appointments/{{SingleAssignedApptId}}/assign/{{MechanicIdToAssign}}

PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin unassign from non-existent appointment (404 expected)
# Expected error code: appointment_not_found.
### [Case][Appointments] DELETE /api/appointments/99999/assign/{{MechanicIdToAssign}}

DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/99999/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Admin unassign mechanic not assigned to appointment (409 expected)
# Expected error code: not_assigned.
### [Case][Appointments] DELETE /api/appointments/{{SingleAssignedApptId}}/assign/{{SecondaryMechanicId}}

DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/{{SecondaryMechanicId}}

###

### [Setup][Appointments] Logout admin, login as non-admin for authz checks
POST {{AutoService_ApiService_HostAddress}}/api/auth/logout

###

### [Setup][Appointments] Login as non-admin mechanic
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{NonAdminEmail}}",
  "password": "{{NonAdminPassword}}"
}

###

### [Negative][Appointments] Non-admin cannot admin-assign mechanic to appointment (403 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/{{MechanicIdToAssign}}

###

### [Negative][Appointments] Non-admin cannot admin-unassign mechanic from appointment (403 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/appointments/{{SingleAssignedApptId}}/assign/{{MechanicIdToAssign}}

# ─────────────────────────────────────────────────────────────
# PROFILE - GET & UPDATE
# ─────────────────────────────────────────────────────────────

@AutoService_ApiService_HostAddress = {{$processEnv AutoService_ApiService_HostAddress}}
@TestPassword = {{$processEnv ARSM_TEST_PASSWORD}}
@AdminEmail = {{$processEnv ARSM_TEST_ADMIN_EMAIL}}
@AdminPassword = {{$processEnv ARSM_TEST_ADMIN_PASSWORD}}
@MatrixRunSuffix = {{$timestamp}}
@ProfileMechanicEmail = {{$processEnv ARSM_TEST_MECHANIC_EMAIL}}
@ProfileCurrentPassword = {{$processEnv ARSM_TEST_MECHANIC_PASSWORD}}
@ProfileConflictEmail = profile.conflict.{{MatrixRunSuffix}}@example.test
@ProfileConflictPhoneSuffix = {{$randomInt 1000000 9999999}}
@ProfileConflictPhone = +3630{{ProfileConflictPhoneSuffix}}


# ─────────────────────────────────────────────────────────────

### [Setup][Profile] Login as admin to seed profile conflict identity
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Setup][Profile] Register mechanic used for duplicate email/phone profile validation
POST {{AutoService_ApiService_HostAddress}}/api/auth/register
Content-Type: application/json

{
  "firstName": "Profile",
  "lastName": "Conflict",
  "email": "{{ProfileConflictEmail}}",
  "password": "{{TestPassword}}",
  "personType": "Mechanic",
  "phoneNumber": "{{ProfileConflictPhone}}",
  "specialization": "GasolineAndDiesel",
  "expertise": ["Engine", "Brakes"]
}

###

### [Setup][Profile] Logout admin before mechanic profile checks
POST {{AutoService_ApiService_HostAddress}}/api/auth/logout

###

### [Setup][Profile] Login as non-admin mechanic (session prerequisite)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{ProfileMechanicEmail}}",
  "password": "{{ProfileCurrentPassword}}"
}

###

### [Positive][Profile] Get own profile
GET {{AutoService_ApiService_HostAddress}}/api/profile

###

### [Positive][Profile] Update own profile (middle name only)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "email": null,
  "phoneNumber": null,
  "middleName": "TestMiddle"
}

###

### [Positive][Profile] Update first and last name
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "UpdatedFirst",
  "lastName": "UpdatedLast"
}

###

### [Positive][Profile] Update all name fields together
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "UpdatedFirst",
  "middleName": "UpdatedMiddle",
  "lastName": "UpdatedLast"
}

###

### [Negative][Profile] Update with duplicate email conflict (409 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "email": "{{ProfileConflictEmail}}"
}

###

### [Negative][Profile] Update with duplicate phone conflict (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "phoneNumber": "{{ProfileConflictPhone}}"
}

###

### [Negative][Profile] Update with invalid email format (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "email": "invalid-email-format"
}

###

### [Negative][Profile] Update with invalid European phone format (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "phoneNumber": "12345"
}

###

### [Negative][Profile] Update with empty firstName (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "   "
}

###

### [Negative][Profile] Update with empty lastName (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "lastName": ""
}

###

### [Positive][Profile] Update phone with local format (default region normalization)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "email": null,
  "phoneNumber": "301112233",
  "middleName": "TestMiddle"
}

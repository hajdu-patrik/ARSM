# ─────────────────────────────────────────────────────────────
# PROFILE - PROFILE CORE
# ─────────────────────────────────────────────────────────────

@AutoService_ApiService_HostAddress = {{$processEnv AutoService_ApiService_HostAddress}}
@TestPassword = {{$processEnv ARSM_TEST_PASSWORD}}
@AdminEmail = {{$processEnv ARSM_TEST_ADMIN_EMAIL}}
@AdminPassword = {{$processEnv ARSM_TEST_ADMIN_PASSWORD}}
@MatrixRunSuffix = {{$timestamp}}
@MatrixEmailOnly = matrix.email.only.{{MatrixRunSuffix}}@example.test
@ProfileMechanicEmail = {{$processEnv ARSM_TEST_MECHANIC_EMAIL}}
@ProfileCurrentPassword = {{$processEnv ARSM_TEST_MECHANIC_PASSWORD}}
@ProfileNewPassword = {{$processEnv ARSM_TEST_MECHANIC_NEW_PASSWORD}}
@MechanicPersonIdForPicture = 7


# ─────────────────────────────────────────────────────────────

### [Setup][Profile] Login as non-admin mechanic (session prerequisite)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{ProfileMechanicEmail}}",
  "password": "{{ProfileCurrentPassword}}"
}

###

### [Positive][Profile] Get own profile
GET {{AutoService_ApiService_HostAddress}}/api/profile

###

### [Positive][Profile] Update own profile (middle name only)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "email": null,
  "phoneNumber": null,
  "middleName": "TestMiddle"
}

###

### [Positive][Profile] Update first and last name
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "UpdatedFirst",
  "lastName": "UpdatedLast"
}

###

### [Positive][Profile] Update all name fields together
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "UpdatedFirst",
  "middleName": "UpdatedMiddle",
  "lastName": "UpdatedLast"
}

###

### [Negative][Profile] Update with empty firstName (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "   "
}

###

### [Negative][Profile] Update with empty lastName (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "lastName": ""
}

###

### [Negative][Profile] Update firstName with space rejected (422 expected)
# "First name may only contain letters and hyphens."
### [Case][Profile] PUT /api/profile

PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "Mary Jane"
}

###

### [Negative][Profile] Update firstName with digit rejected (422 expected)
# "First name may only contain letters and hyphens."
### [Case][Profile] PUT /api/profile

PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "John2"
}

###

### [Negative][Profile] Update lastName with apostrophe rejected (422 expected)
# "Last name may only contain letters and hyphens."
### [Case][Profile] PUT /api/profile

PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "lastName": "O'Brien"
}

###

### [Negative][Profile] Update middleName with space rejected (422 expected)
# "Middle name may only contain letters and hyphens."
### [Case][Profile] PUT /api/profile

PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "middleName": "Van Der"
}

###

### [Positive][Profile] Update phone with local format (default region normalization)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "email": null,
  "phoneNumber": "301112233",
  "middleName": "TestMiddle"
}

###

### [Positive][Profile] Change password
POST {{AutoService_ApiService_HostAddress}}/api/profile/change-password
Content-Type: application/json

{
  "currentPassword": "{{ProfileCurrentPassword}}",
  "newPassword": "{{ProfileNewPassword}}",
  "confirmNewPassword": "{{ProfileNewPassword}}"
}

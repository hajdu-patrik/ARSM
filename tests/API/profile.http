@AutoService_ApiService_HostAddress = https://localhost:5200
@TestPassword = Test@1234
@AdminEmail = gabor.kovacs@example.com
@AdminPassword = {{$processEnv ARSM_ADMIN_PASSWORD}}
@MatrixRunSuffix = 20260403a
@MatrixEmailOnly = matrix.email.only.{{MatrixRunSuffix}}@example.com
@ProfileMechanicEmail = peter.nagy@example.com
@ProfileCurrentPassword = {{$processEnv ARSM_ADMIN_PASSWORD}}
@ProfileNewPassword = Test@12345A
@MechanicPersonIdForPicture = 7

### [Setup][Profile] Login as non-admin mechanic (session prerequisite)
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{ProfileMechanicEmail}}",
  "password": "{{ProfileCurrentPassword}}"
}

###

### [Positive][Profile] Get own profile
GET {{AutoService_ApiService_HostAddress}}/api/profile

###

### [Positive][Profile] Update own profile (middle name only)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "email": null,
  "phoneNumber": null,
  "middleName": "TestMiddle"
}

###

### [Positive][Profile] Update first and last name
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "UpdatedFirst",
  "lastName": "UpdatedLast"
}

###

### [Positive][Profile] Update all name fields together
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "UpdatedFirst",
  "middleName": "UpdatedMiddle",
  "lastName": "UpdatedLast"
}

###

### [Negative][Profile] Update with empty firstName (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "   "
}

###

### [Negative][Profile] Update with empty lastName (422 expected)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "lastName": ""
}

###

### [Negative][Profile] Update firstName with space rejected (422 expected)
# "First name may only contain letters and hyphens."
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "Mary Jane"
}

###

### [Negative][Profile] Update firstName with digit rejected (422 expected)
# "First name may only contain letters and hyphens."
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "firstName": "John2"
}

###

### [Negative][Profile] Update lastName with apostrophe rejected (422 expected)
# "Last name may only contain letters and hyphens."
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "lastName": "O'Brien"
}

###

### [Negative][Profile] Update middleName with space rejected (422 expected)
# "Middle name may only contain letters and hyphens."
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "middleName": "Van Der"
}

###

### [Positive][Profile] Update phone with local Hungarian format (no 36/06 prefix)
PUT {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "email": null,
  "phoneNumber": "301112233",
  "middleName": "TestMiddle"
}

###

### [Positive][Profile] Change password
POST {{AutoService_ApiService_HostAddress}}/api/profile/change-password
Content-Type: application/json

{
  "currentPassword": "{{ProfileCurrentPassword}}",
  "newPassword": "{{ProfileNewPassword}}",
  "confirmNewPassword": "{{ProfileNewPassword}}"
}

###

### [Positive][Profile] Get profile picture (200 or 404 if none)
GET {{AutoService_ApiService_HostAddress}}/api/profile/picture

###

### [Positive][Profile] Get mechanic profile picture by person id (200 or 404 if none)
GET {{AutoService_ApiService_HostAddress}}/api/profile/picture/{{MechanicPersonIdForPicture}}

###

### [Manual][Profile] Open realtime profile picture updates stream (authorized SSE)
GET {{AutoService_ApiService_HostAddress}}/api/profile/picture/updates

###

### [Note][Profile] Multipart upload is not supported in .http reliably; use curl for PUT /api/profile/picture
# curl example:
# curl -k -X PUT "{{AutoService_ApiService_HostAddress}}/api/profile/picture" \
#   -H "Cookie: autoservice_at=<ACCESS_COOKIE>; autoservice_rt=<REFRESH_COOKIE>" \
#   -F "file=@C:/path/to/profile-picture.png"
#
# Negative magic-byte checks:
# 1) MIME/content mismatch should return 422.
#    curl -k -X PUT "{{AutoService_ApiService_HostAddress}}/api/profile/picture" \
#      -H "Cookie: autoservice_at=<ACCESS_COOKIE>; autoservice_rt=<REFRESH_COOKIE>" \
#      -F "file=@C:/path/to/image.png;type=image/jpeg"
# 2) Non-image payload with image MIME should return 422.
#    curl -k -X PUT "{{AutoService_ApiService_HostAddress}}/api/profile/picture" \
#      -H "Cookie: autoservice_at=<ACCESS_COOKIE>; autoservice_rt=<REFRESH_COOKIE>" \
#      -F "file=@C:/path/to/not-an-image.txt;type=image/png"

###

### [Positive][Profile] Remove profile picture
DELETE {{AutoService_ApiService_HostAddress}}/api/profile/picture

###

### [Setup][Profile] Login as admin for self-delete negative test
POST {{AutoService_ApiService_HostAddress}}/api/auth/login
Content-Type: application/json

{
  "email": "{{AdminEmail}}",
  "password": "{{AdminPassword}}"
}

###

### [Negative][Profile] Admin self-delete forbidden (403 expected)
DELETE {{AutoService_ApiService_HostAddress}}/api/profile
Content-Type: application/json

{
  "currentPassword": "{{AdminPassword}}"
}

###


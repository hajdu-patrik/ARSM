# ─────────────────────────────────────────────────────────────
# VEHICLES - CREATE VALIDATION AND CONFLICTS
# ─────────────────────────────────────────────────────────────

@AutoService_ApiService_HostAddress = {{$processEnv AutoService_ApiService_HostAddress}}
@SeedCustomerId = 1


# ─────────────────────────────────────────────────────────────

### [Negative][Vehicles] Create vehicle with missing required fields (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}/vehicles
Content-Type: application/json

{
  "licensePlate": "",
  "brand": "Skoda",
  "model": "Octavia",
  "year": 2020,
  "mileageKm": 45000,
  "enginePowerHp": 150,
  "engineTorqueNm": 320
}

###

### [Negative][Vehicles] Create vehicle with invalid year (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}/vehicles
Content-Type: application/json

{
  "licensePlate": "BAD-YR1",
  "brand": "Skoda",
  "model": "Octavia",
  "year": 1800,
  "mileageKm": 0,
  "enginePowerHp": 100,
  "engineTorqueNm": 200
}

###

### [Negative][Vehicles] Create vehicle with non-European script in plate (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}/vehicles
Content-Type: application/json

{
  "licensePlate": "\u0627\u0628-123",
  "brand": "Skoda",
  "model": "Octavia",
  "year": 2020,
  "mileageKm": 0,
  "enginePowerHp": 100,
  "engineTorqueNm": 200
}

###

### [Negative][Vehicles] Create vehicle with negative mileage (422 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}/vehicles
Content-Type: application/json

{
  "licensePlate": "BAD-MI1",
  "brand": "Skoda",
  "model": "Octavia",
  "year": 2020,
  "mileageKm": -1,
  "enginePowerHp": 150,
  "engineTorqueNm": 320
}

###

### [Negative][Vehicles] Create vehicle with duplicate license plate (409 expected)
POST {{AutoService_ApiService_HostAddress}}/api/customers/{{SeedCustomerId}}/vehicles
Content-Type: application/json

{
  "licensePlate": "ABC-101",
  "brand": "Volkswagen",
  "model": "Golf",
  "year": 2018,
  "mileageKm": 124500,
  "enginePowerHp": 110,
  "engineTorqueNm": 250
}

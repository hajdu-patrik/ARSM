# ─────────────────────────────────────────────────────────────
# ARSM HTTP Test Environment Variables — TEMPLATE
# ─────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your local values.
#
#   cp tests/.env.example tests/.env
#
# These variables are consumed by {{$processEnv VAR}} in .http files.
# Values below match the demo seed data from DemoDataInitializer.cs
# when using appsettings.Local.json defaults.
# ─────────────────────────────────────────────────────────────

# API base URL (must match your running ApiService endpoint)
AutoService_ApiService_HostAddress=https://localhost:5200

# Shared test password (must match DemoData:MechanicPassword)
ARSM_TEST_PASSWORD=CHANGE_ME
ARSM_TEST_WRONG_PASSWORD=Wrong_Password.999

# Admin account (first seeded mechanic — has "Admin" role)
ARSM_TEST_ADMIN_EMAIL=gabor.kovacs@example.com
ARSM_TEST_ADMIN_PASSWORD=CHANGE_ME

# Non-admin mechanic account (second seeded mechanic)
ARSM_TEST_MECHANIC_EMAIL=peter.nagy@example.com
ARSM_TEST_MECHANIC_PASSWORD=CHANGE_ME
ARSM_TEST_MECHANIC_NEW_PASSWORD=CHANGE_ME

# Known customer email (passive record — no login, used for negative tests)
ARSM_TEST_CUSTOMER_EMAIL=anna.toth@example.com
